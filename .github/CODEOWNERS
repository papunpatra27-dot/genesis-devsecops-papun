# CODEOWNERS
# Requires review from a senior engineer on any change to CI/CD,
# Kubernetes, or infrastructure directories.
# See: https://docs.github.com/en/repositories/managing-your-repositorys-settings-and-features/customizing-your-repository/about-code-owners

# Global fallback — all files require at least one review
*                           @REPLACE_GITHUB_ORG/platform-team

# Pipeline changes — require senior platform engineer sign-off
.github/workflows/          @REPLACE_GITHUB_ORG/senior-platform-engineers
.github/CODEOWNERS          @REPLACE_GITHUB_ORG/senior-platform-engineers

# Kubernetes manifests — any change can break production
k8s/                        @REPLACE_GITHUB_ORG/senior-platform-engineers

# Infrastructure as Code — Terraform changes affect real cloud resources
infrastructure/             @REPLACE_GITHUB_ORG/senior-platform-engineers

# SLO definitions — changes to thresholds must be reviewed
slo/                        @REPLACE_GITHUB_ORG/senior-platform-engineers

# Application source — standard team review
app/                        @REPLACE_GITHUB_ORG/platform-team
